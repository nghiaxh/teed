{
	"name": "@nghiaxh/daily-feed",
	"version": "0.0.0",
	"license": "MIT",
	"bin": {
		"dfd": "dist/cli.js"
	},
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "prettier --check . && xo && ava",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@types/react-dom": "19.2.3",
		"html-entities": "^2.6.0",
		"ink": "^6.8.0",
		"ink-text-input": "^6.0.0",
		"meow": "^11.0.0",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"remove-accents": "^0.5.0",
		"rss-parser": "^3.13.0",
		"stopword": "^3.1.5"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/node": "^25.9.1",
		"@types/react": "19.2.14",
		"@types/stopword": "^2.0.3",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.9.3",
		"xo": "^2.0.2"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config",
	"keywords": [
		"rss",
		"cli",
		"news",
		"vietnam"
	]
}
